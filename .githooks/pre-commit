#!/usr/bin/env bash
set -euo pipefail

# Files that predate the 400-line limit.  Remove an entry once the file has
# been refactored below the threshold and its per-file-ignores entry removed
# from pyproject.toml.
MAX_LINES=400
LEGACY_LARGE_FILES=(
    "tests/orchestrator/test_sbatch.py"
    "packages/relaymd-worker/src/relaymd/worker/main.py"
    "packages/relaymd-worker/tests/test_main_loop.py"
    "packages/relaymd-worker/src/relaymd/worker/bootstrap.py"
    "src/relaymd/orchestrator/services/slurm_provisioning_service.py"
    "src/relaymd/orchestrator/services/worker_lifecycle_service.py"
    "src/relaymd/orchestrator/main.py"
    "src/relaymd/orchestrator/routers/jobs_operator.py"
    "src/relaymd/orchestrator/config.py"
    "src/relaymd/cli/commands/service.py"
)

is_generated_api_client_file() {
    local file="$1"
    [[ "$file" == packages/relaymd-api-client/src/relaymd_api_client/* ]]
}

mapfile -t staged_py < <(git diff --cached --name-only --diff-filter=ACMR | grep '\.py$' || true)

if [[ ${#staged_py[@]} -gt 0 ]]; then
    if command -v uv > /dev/null 2>&1; then
        export UV_CACHE_DIR="${UV_CACHE_DIR:-/tmp/uv-cache}"
        uv run ruff format "${staged_py[@]}"
        uv run ruff check --fix "${staged_py[@]}"
        uv run pyright "${staged_py[@]}"
    else
        ruff format "${staged_py[@]}"
        ruff check --fix "${staged_py[@]}"
        pyright "${staged_py[@]}"
    fi

    # Enforce max-module-lines = 400.
    # Legacy files above this limit are exempt until explicitly refactored.
    for f in "${staged_py[@]}"; do
        # Generated OpenAPI client files are machine-produced and can exceed
        # line-count thresholds; enforce limits on hand-written code only.
        if is_generated_api_client_file "$f"; then
            continue
        fi
        lines=$(wc -l < "$f")
        if [[ $lines -gt $MAX_LINES ]]; then
            # Check if this file is in the legacy exemption list.
            exempt=0
            for legacy in "${LEGACY_LARGE_FILES[@]}"; do
                if [[ "$f" == "$legacy" || "$f" == "./$legacy" ]]; then
                    exempt=1
                    break
                fi
            done
            if [[ $exempt -eq 0 ]]; then
                echo ""
                echo "pre-commit: $f has $lines lines (max $MAX_LINES)."
                echo "  Split the file before committing, or discuss adding a"
                echo "  legacy exemption if this is a known large module."
                exit 1
            fi
        fi
    done
fi
