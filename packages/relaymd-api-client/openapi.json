          },
          "vram_gb": {
            "type": "integer",
            "title": "Vram Gb"
          },
          "last_heartbeat": {
            "type": "string",
            "format": "date-time",
            "title": "Last Heartbeat"
          }
        },
        "type": "object",
        "required": [
          "id",
          "platform",
          "gpu_model",
          "gpu_count",
          "vram_gb",
          "last_heartbeat"
        ],
        "title": "WorkerRead"
