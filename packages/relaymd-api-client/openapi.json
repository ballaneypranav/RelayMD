          "title": {
            "type": "string",
            "title": "Title"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "input_bundle_path": {
            "type": "string",
            "title": "Input Bundle Path"
          },
          "latest_checkpoint_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latest Checkpoint Path"
          },
          "last_checkpoint_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Checkpoint At"
          },
          "assigned_worker_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Assigned Worker Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "input_bundle_path",
          "latest_checkpoint_path",
          "last_checkpoint_at",
          "assigned_worker_id",
          "created_at",
          "updated_at"
        ],
        "title": "JobRead"
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "queued",
          "assigned",
          "running",
          "completed",
          "failed",
          "cancelled"
        ],
        "title": "JobStatus"
      },
      "NoJobAvailable": {
        "properties": {
          "status": {
            "type": "string",
            "const": "no_job_available",
            "title": "Status",
            "default": "no_job_available"
          }
        },
        "type": "object",
        "title": "NoJobAvailable"
      },
      "Platform": {
        "type": "string",
        "enum": [
