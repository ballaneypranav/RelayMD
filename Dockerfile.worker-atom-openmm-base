FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

LABEL relaymd.component=worker \
      relaymd.worker_image_key=atom-openmm \
      relaymd.worker_image_name=AToM-OpenMM

ENV DEBIAN_FRONTEND=noninteractive PYTHONDONTWRITEBYTECODE=1 PYTHONNOUSERSITE=1 PYTHONUNBUFFERED=1 \
    ATOM_REPO_URL=https://github.com/ballaneypranav/AToM-OpenMM \
    ATOM_REPO_REF=71f2f4e6b90f3cfd8ff3ab0ec46e32922e9c2f56 \
    MAMBA_ROOT_PREFIX=/opt/micromamba PATH=/opt/atom-openmm/bin:${PATH} \
    RELAYMD_WORKER_IMAGE_KEY=atom-openmm

RUN apt-get update && apt-get install -y --no-install-recommends software-properties-common ca-certificates gnupg curl git wget bzip2 bash coreutils tar procps python3-pip \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && mkdir -p --mode=0755 /usr/share/keyrings \
    && curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/jammy.noarmor.gpg -o /usr/share/keyrings/tailscale-archive-keyring.gpg \
    && curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/jammy.tailscale-keyring.list -o /etc/apt/sources.list.d/tailscale.list \
    && apt-get update && apt-get install -y --no-install-recommends python3.11 python3.11-venv python3.11-distutils tailscale \
    && curl -fLsS https://micro.mamba.pm/api/micromamba/linux-64/2.3.3 -o /tmp/micromamba.tar.bz2 \
    && echo 'e7274528ceb9c20d048a428d6c22d7e02e268f8ffb762c4c365422347c8b8ba2  /tmp/micromamba.tar.bz2' | sha256sum -c - \
    && tar -xjf /tmp/micromamba.tar.bz2 -C /usr/local/bin --strip-components=1 bin/micromamba \
    && rm /tmp/micromamba.tar.bz2 \
    && micromamba create -y -p /opt/atom-openmm -c conda-forge python=3.11 openmm=8.4.0 cuda-version=12.6 configobj numpy setproctitle pip \
    && micromamba clean -a -y && ln -sf /opt/atom-openmm/bin/python /usr/local/bin/python \
    && python -m pip install --no-cache-dir --upgrade pip uv \
    && uv pip install --system --no-cache "git+${ATOM_REPO_URL}@${ATOM_REPO_REF}" hatchling "attrs>=21.3.0" boto3 "httpx[socks]>=0.24.1" "infisical-python>=2.0,<2.2" nvidia-ml-py orjson "pydantic>=2.0" "pydantic-settings>=2.0" "sqlmodel>=0.0.18" structlog "tenacity>=8.2" \
    && rm -rf /var/lib/apt/lists/*

RUN python -c "import atom_openmm, openmm; assert openmm.version.version.startswith('8.4')"
