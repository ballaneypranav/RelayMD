# Copy to: /depot/plow/data/pballane/relaymd-service/config/relaymd-service.env
# Protect with: chmod 600

# Required for orchestrator startup (Infisical bootstrap token)
INFISICAL_TOKEN="<client_id>:<client_secret>"

# Required when worker image is pulled from a private GHCR registry at job runtime.
# Set to a GitHub username and a PAT with read:packages scope.
# Not needed when using a pre-pulled SIF via sif_path in relaymd-config.yaml.
APPTAINER_DOCKER_USERNAME="<github_username>"
APPTAINER_DOCKER_PASSWORD="<github_pat_read_packages>"

# Optional but recommended: pin service operations to one frontend host.
RELAYMD_PRIMARY_HOST="gilbreth-fe03"

# Optional override for GHCR owner when using relaymd-service-pull auto mode.
# If unset, relaymd-service-pull auto mode defaults to:
#   gh repo view --json owner -q .owner.login
# RELAYMD_GHCR_OWNER="ballaneypranav"

# Optional override for latest release manifest URI used by relaymd-service-pull latest.
# RELAYMD_RELEASE_MANIFEST_URI="https://github.com/ballaneypranav/relaymd/releases/latest/download/relaymd-release-manifest.json"

# Optional override for shared lock/status metadata file.
# RELAYMD_STATUS_FILE="/depot/plow/data/pballane/relaymd-service/state/relaymd-service.status"

# Optional heartbeat/write cadence for service wrappers.
# RELAYMD_HEARTBEAT_INTERVAL_SECONDS="30"
# RELAYMD_HEARTBEAT_STALE_SECONDS="120"

# Optional startup grace period (seconds) before wrappers declare early failure.
# STARTUP_GRACE_SECONDS="3"

# Required for dashboard proxy startup
RELAYMD_API_TOKEN="<relaymd-api-token>"
RELAYMD_DASHBOARD_USERNAME="<username>"
RELAYMD_DASHBOARD_PASSWORD="<password>"
