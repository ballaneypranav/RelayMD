# Copy to: /depot/plow/data/pballane/relaymd-service/config/relaymd-service.env
# Protect with: chmod 600

# Required for orchestrator startup (Infisical bootstrap token)
INFISICAL_TOKEN="<client_id>:<client_secret>"

# Optional but recommended: pin service operations to one frontend host.
RELAYMD_PRIMARY_HOST="gilbreth-fe03"

# Optional override for shared lock/status metadata file.
# RELAYMD_STATUS_FILE="/depot/plow/data/pballane/relaymd-service/state/relaymd-service.status"

# Required for dashboard proxy startup
RELAYMD_API_TOKEN="<relaymd-api-token>"
RELAYMD_DASHBOARD_USERNAME="<username>"
RELAYMD_DASHBOARD_PASSWORD="<password>"
