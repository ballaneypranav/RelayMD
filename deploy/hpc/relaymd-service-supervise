#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 5 ]]; then
    echo "Usage: relaymd-service-supervise <orchestrator|proxy> <wrapper-log> <session-name> <port> <command>" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/relaymd-service-lib.sh"

SERVICE_NAME="$1"
WRAPPER_LOG="$2"
SESSION_NAME="$3"
SERVICE_PORT="$4"
SERVICE_COMMAND="$5"
CURRENT_HOST="${CURRENT_HOST:-$(hostname -s 2>/dev/null || hostname)}"
HEARTBEAT_INTERVAL_SECONDS="${RELAYMD_HEARTBEAT_INTERVAL_SECONDS:-30}"

case "${SERVICE_NAME}" in
    orchestrator)
        PREFIX="ORCHESTRATOR"
        ;;
    proxy)
        PREFIX="PROXY"
        ;;
    *)
        echo "Unknown service: ${SERVICE_NAME}" >&2
        exit 1
        ;;
esac

mkdir -p "$(dirname "${WRAPPER_LOG}")"
start_at="$(status_now_utc)"

{
    printf '[%s] ===== RelayMD %s wrapper start =====\n' "${start_at}" "${SERVICE_NAME}"
    printf '[%s] host=%s session=%s port=%s image=%s\n' "${start_at}" "${CURRENT_HOST}" "${SESSION_NAME}" "${SERVICE_PORT}" "${RELAYMD_ORCHESTRATOR_SIF:-unknown}"
    printf '[%s] command=%s\n' "${start_at}" "${SERVICE_COMMAND}"
} >> "${WRAPPER_LOG}"

status_set_pairs \
    HOST "${CURRENT_HOST}" \
    "${PREFIX}_ACTIVE" "1" \
    "${PREFIX}_PORT" "${SERVICE_PORT}" \
    "${PREFIX}_SESSION" "${SESSION_NAME}" \
    "${PREFIX}_HEARTBEAT_AT" "${start_at}" \
    "${PREFIX}_LAST_START_AT" "${start_at}" \
    "${PREFIX}_LAST_EXIT_AT" "" \
    "${PREFIX}_LAST_EXIT_CODE" ""

set +e
bash -lc "${SERVICE_COMMAND}" >> "${WRAPPER_LOG}" 2>&1 &
child_pid=$!
set -e

heartbeat_loop() {
    while kill -0 "${child_pid}" 2>/dev/null; do
        sleep "${HEARTBEAT_INTERVAL_SECONDS}"
        kill -0 "${child_pid}" 2>/dev/null || break
        status_set_pairs \
            HOST "${CURRENT_HOST}" \
            "${PREFIX}_ACTIVE" "1" \
            "${PREFIX}_HEARTBEAT_AT" "$(status_now_utc)"
    done
}

forward_and_wait() {
    local sig="$1"
    if kill -0 "${child_pid}" 2>/dev/null; then
        kill "-${sig}" "${child_pid}" 2>/dev/null || true
    fi
}

trap 'forward_and_wait TERM' TERM
trap 'forward_and_wait INT' INT

heartbeat_loop &
heartbeat_pid=$!

set +e
wait "${child_pid}"
exit_code=$?
set -e

kill "${heartbeat_pid}" 2>/dev/null || true
wait "${heartbeat_pid}" 2>/dev/null || true

exit_at="$(status_now_utc)"
status_set_pairs \
    HOST "${CURRENT_HOST}" \
    "${PREFIX}_ACTIVE" "0" \
    "${PREFIX}_HEARTBEAT_AT" "${exit_at}" \
    "${PREFIX}_LAST_EXIT_AT" "${exit_at}" \
    "${PREFIX}_LAST_EXIT_CODE" "${exit_code}"

printf '[%s] ===== RelayMD %s wrapper exit code=%s =====\n' "${exit_at}" "${SERVICE_NAME}" "${exit_code}" >> "${WRAPPER_LOG}"

exit "${exit_code}"
