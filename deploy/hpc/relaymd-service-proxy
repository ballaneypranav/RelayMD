#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: relaymd-service-proxy [--force]

Options:
  -f, --force    Override host pin/lock checks and take ownership on this host.
  -h, --help     Show this help.
EOF
}

FORCE=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--force)
            FORCE=1
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

SESSION_NAME="${SESSION_NAME:-relaymd-service-proxy}"
ORCHESTRATOR_SESSION_NAME="${ORCHESTRATOR_SESSION_NAME:-relaymd-service}"
RELAYMD_SERVICE_ROOT="${RELAYMD_SERVICE_ROOT:-/depot/plow/apps/relaymd}"
CURRENT_LINK="${CURRENT_LINK:-${RELAYMD_SERVICE_ROOT}/current}"
RELAYMD_DATA_ROOT="${RELAYMD_DATA_ROOT:-/depot/plow/data/pballane/relaymd-service}"
RELAYMD_ENV_FILE="${RELAYMD_ENV_FILE:-${RELAYMD_DATA_ROOT}/config/relaymd-service.env}"
RELAYMD_ORCHESTRATOR_SIF="${RELAYMD_ORCHESTRATOR_SIF:-${CURRENT_LINK}/relaymd-orchestrator.sif}"
RELAYMD_BIND_PATHS="${RELAYMD_BIND_PATHS:-${RELAYMD_DATA_ROOT}:${RELAYMD_DATA_ROOT}}"
RELAYMD_SCRATCH_ROOT="${RELAYMD_SCRATCH_ROOT:-${SCRATCH:-${RCAC_SCRATCH:-/scratch/gilbreth/${USER}}}/relaymd-service}"
RELAYMD_PRIMARY_HOST="${RELAYMD_PRIMARY_HOST:-}"
RELAYMD_STATUS_FILE="${RELAYMD_STATUS_FILE:-${RELAYMD_DATA_ROOT}/state/relaymd-service.status}"
RELAYMD_STATUS_DIR="$(dirname "${RELAYMD_STATUS_FILE}")"
ORCHESTRATOR_PORT="${ORCHESTRATOR_PORT:-36158}"
PROXY_PORT="${PROXY_PORT:-36159}"
CURRENT_HOST="$(hostname -s 2>/dev/null || hostname)"

# Use scratch-backed temp/cache for Apptainer runtime mounts to avoid /tmp exhaustion.
APPTAINER_TMPDIR="${APPTAINER_TMPDIR:-${RELAYMD_SCRATCH_ROOT}/apptainer/tmp}"
APPTAINER_CACHEDIR="${APPTAINER_CACHEDIR:-${RELAYMD_SCRATCH_ROOT}/apptainer/cache}"
TMPDIR="${TMPDIR:-${APPTAINER_TMPDIR}}"
export APPTAINER_TMPDIR APPTAINER_CACHEDIR TMPDIR

status_get() {
    local key="$1"
    local line
    [[ -f "${RELAYMD_STATUS_FILE}" ]] || return 0
    line="$(grep -E "^${key}=" "${RELAYMD_STATUS_FILE}" | head -n1 || true)"
    printf '%s' "${line#*=}"
}

status_write() {
    local host="$1"
    local orchestrator_active="$2"
    local proxy_active="$3"
    local updated_at tmp_file

    updated_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    tmp_file="${RELAYMD_STATUS_FILE}.tmp.$$"

    cat > "${tmp_file}" <<EOF
HOST=${host}
UPDATED_AT=${updated_at}
UPDATED_BY=${USER}
ORCHESTRATOR_ACTIVE=${orchestrator_active}
ORCHESTRATOR_PORT=${ORCHESTRATOR_PORT}
ORCHESTRATOR_SESSION=${ORCHESTRATOR_SESSION_NAME}
PROXY_ACTIVE=${proxy_active}
PROXY_PORT=${PROXY_PORT}
PROXY_SESSION=${SESSION_NAME}
EOF

    mv "${tmp_file}" "${RELAYMD_STATUS_FILE}"
    chmod 664 "${RELAYMD_STATUS_FILE}" 2>/dev/null || true
}

mkdir -p "${APPTAINER_TMPDIR}" "${APPTAINER_CACHEDIR}" "${RELAYMD_STATUS_DIR}"
chmod 700 "${APPTAINER_TMPDIR}" "${APPTAINER_CACHEDIR}" 2>/dev/null || true

if [[ -f "${RELAYMD_ENV_FILE}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${RELAYMD_ENV_FILE}"
    set +a
fi

if [[ -n "${RELAYMD_PRIMARY_HOST}" && "${CURRENT_HOST}" != "${RELAYMD_PRIMARY_HOST}" && "${FORCE}" -ne 1 ]]; then
    echo "Refusing to start on ${CURRENT_HOST}: RELAYMD_PRIMARY_HOST is '${RELAYMD_PRIMARY_HOST}'." >&2
    echo "SSH to ${RELAYMD_PRIMARY_HOST} or rerun with --force." >&2
    exit 1
fi

taking_over=0
locked_host="$(status_get HOST)"
locked_orchestrator_active="$(status_get ORCHESTRATOR_ACTIVE)"
locked_proxy_active="$(status_get PROXY_ACTIVE)"

if [[ -n "${locked_host}" && "${locked_host}" != "${CURRENT_HOST}" ]]; then
    if [[ "${locked_orchestrator_active}" == "1" || "${locked_proxy_active}" == "1" ]]; then
        if [[ "${FORCE}" -ne 1 ]]; then
            echo "Refusing to start on ${CURRENT_HOST}: lock indicates active RelayMD service on ${locked_host}." >&2
            echo "Lock file: ${RELAYMD_STATUS_FILE}" >&2
            echo "Use --force only when you have confirmed the other host is inactive." >&2
            exit 1
        fi
        taking_over=1
        echo "WARNING: taking over active lock from ${locked_host} due to --force." >&2
    fi
fi

if [[ -z "${RELAYMD_API_TOKEN:-}" ]]; then
    echo "RELAYMD_API_TOKEN is required" >&2
    exit 1
fi

if [[ -z "${RELAYMD_DASHBOARD_USERNAME:-}" ]]; then
    echo "RELAYMD_DASHBOARD_USERNAME is required" >&2
    exit 1
fi

if [[ -z "${RELAYMD_DASHBOARD_PASSWORD:-}" ]]; then
    echo "RELAYMD_DASHBOARD_PASSWORD is required" >&2
    exit 1
fi

if [[ ! -f "${RELAYMD_ORCHESTRATOR_SIF}" ]]; then
    echo "Orchestrator SIF not found: ${RELAYMD_ORCHESTRATOR_SIF}" >&2
    exit 1
fi

if tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
    if [[ "${taking_over}" -eq 1 ]]; then
        orchestrator_active=0
    else
        orchestrator_active="$(status_get ORCHESTRATOR_ACTIVE)"
        if [[ ! "${orchestrator_active}" =~ ^[01]$ ]]; then
            orchestrator_active=0
        fi
    fi
    status_write "${CURRENT_HOST}" "${orchestrator_active}" 1
    echo "tmux session '${SESSION_NAME}' already running"
    echo "attach: tmux attach -t ${SESSION_NAME}"
    exit 0
fi

tmux new-session -d -s "${SESSION_NAME}" -n "relaymd-proxy"

# Inject credentials via session environment so they are not exposed in command-line args.
tmux set-environment -t "${SESSION_NAME}" APPTAINERENV_RELAYMD_API_TOKEN "${RELAYMD_API_TOKEN}"
tmux set-environment -t "${SESSION_NAME}" APPTAINERENV_RELAYMD_DASHBOARD_USERNAME "${RELAYMD_DASHBOARD_USERNAME}"
tmux set-environment -t "${SESSION_NAME}" APPTAINERENV_RELAYMD_DASHBOARD_PASSWORD "${RELAYMD_DASHBOARD_PASSWORD}"
tmux set-environment -t "${SESSION_NAME}" APPTAINER_TMPDIR "${APPTAINER_TMPDIR}"
tmux set-environment -t "${SESSION_NAME}" APPTAINER_CACHEDIR "${APPTAINER_CACHEDIR}"
tmux set-environment -t "${SESSION_NAME}" TMPDIR "${TMPDIR}"

printf -v COMMAND \
    "apptainer exec --cleanenv --writable-tmpfs --bind %q %q relaymd orchestrator proxy --host 127.0.0.1 --port %q --upstream-url http://127.0.0.1:%q" \
    "${RELAYMD_BIND_PATHS}" "${RELAYMD_ORCHESTRATOR_SIF}" "${PROXY_PORT}" "${ORCHESTRATOR_PORT}"

# Start the proxy command after session env is set so APPTAINERENV_* is inherited.
tmux respawn-pane -k -t "${SESSION_NAME}:relaymd-proxy" "${COMMAND}"

if [[ "${taking_over}" -eq 1 ]]; then
    orchestrator_active=0
else
    orchestrator_active="$(status_get ORCHESTRATOR_ACTIVE)"
    if [[ ! "${orchestrator_active}" =~ ^[01]$ ]]; then
        orchestrator_active=0
    fi
fi
status_write "${CURRENT_HOST}" "${orchestrator_active}" 1

echo "started relaymd dashboard proxy in tmux session '${SESSION_NAME}'"
echo "host:   ${CURRENT_HOST}"
echo "port:   ${PROXY_PORT}"
echo "status: ${RELAYMD_STATUS_FILE}"
echo "attach: tmux attach -t ${SESSION_NAME}"
echo "stop:   tmux kill-session -t ${SESSION_NAME}"
