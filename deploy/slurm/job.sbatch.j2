#!/bin/bash
# RelayMD worker SLURM template for {{ cluster_name }}
# Generated by orchestrator Jinja2 rendering.

#SBATCH --job-name=relaymd-worker-{{ cluster_name }}
#SBATCH --partition={{ partition }}
#SBATCH --account={{ account }}
#SBATCH --gres={{ gres | default("gpu:" ~ gpu_type ~ ":" ~ gpu_count) }}
{% if nodes %}
#SBATCH --nodes={{ nodes }}
{% endif %}
{% if ntasks %}
#SBATCH --ntasks={{ ntasks }}
{% endif %}
{% if qos %}
#SBATCH --qos={{ qos }}
{% endif %}
{% if memory %}
#SBATCH --mem={{ memory }}
{% endif %}
{% if memory_per_gpu %}
#SBATCH --mem-per-gpu={{ memory_per_gpu }}
{% endif %}
#SBATCH --time={{ wall_time | default("4:00:00") }}
#SBATCH --signal=TERM@{{ slurm_sigterm_margin_seconds | default(300) }}
#SBATCH --output=slurm-relaymd-%j.out
#SBATCH --error=slurm-relaymd-%j.err
#SBATCH --export=ALL,INFISICAL_BOOTSTRAP_TOKEN={{ infisical_token }}

set -euo pipefail

export INFISICAL_TOKEN="${INFISICAL_BOOTSTRAP_TOKEN}"
{% if apptainer_docker_username and apptainer_docker_password %}
export APPTAINER_DOCKER_USERNAME="{{ apptainer_docker_username }}"
export APPTAINER_DOCKER_PASSWORD="{{ apptainer_docker_password }}"
export SINGULARITY_DOCKER_USERNAME="${APPTAINER_DOCKER_USERNAME}"
export SINGULARITY_DOCKER_PASSWORD="${APPTAINER_DOCKER_PASSWORD}"
{% endif %}

apptainer exec --nv --cleanenv --writable-tmpfs --bind /tmp:/tmp \
  --env INFISICAL_TOKEN="${INFISICAL_BOOTSTRAP_TOKEN}" \
  --env WORKER_PLATFORM="{{ worker_platform | default("hpc") }}" \
  --env HEARTBEAT_INTERVAL_SECONDS="{{ worker_heartbeat_interval_seconds | default(60) }}" \
  --env CHECKPOINT_POLL_INTERVAL_SECONDS="{{ worker_checkpoint_poll_interval_seconds | default(300) }}" \
  --env ORCHESTRATOR_TIMEOUT_SECONDS="{{ worker_orchestrator_timeout_seconds | default(30.0) }}" \
  --env SIGTERM_CHECKPOINT_WAIT_SECONDS="{{ worker_sigterm_checkpoint_wait_seconds | default(60) }}" \
  --env SIGTERM_CHECKPOINT_POLL_SECONDS="{{ worker_sigterm_checkpoint_poll_seconds | default(2) }}" \
  --env SIGTERM_PROCESS_WAIT_SECONDS="{{ worker_sigterm_process_wait_seconds | default(10) }}" \
  {{ apptainer_image | default(sif_path) }} python -m relaymd.worker
