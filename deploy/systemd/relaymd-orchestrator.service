[Unit]
Description=RelayMD Orchestrator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=uvicorn relaymd.orchestrator.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
Environment=RELAYMD_CONFIG=%h/.config/relaymd/config.yaml
# Environment=RELAYMD_API_TOKEN=change-me
# Environment=INFISICAL_TOKEN=<client_id>:<client_secret>

[Install]
WantedBy=default.target
